{
  "version": 2,
  "functions": {
    "src/server.ts": {
      "includeFiles": "prisma/**",
      "excludeFiles": "node_modules/.prisma/client/libquery_engine-*"
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "src/server.ts"
    }
  ],
  "crons": [
    {
      "path": "/api/public/cron/sessions",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/public/cron/announcements",
      "schedule": "0 1 * * *"
    }
  ]
}
